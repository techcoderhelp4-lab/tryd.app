<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Row 1: Phase · Round · Remaining -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- Phase -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_phase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WORK"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHASE"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Round -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_round"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/3"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUND"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Remaining -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:45"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REMAINING"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="12dp" />

    <!-- Pause button (running) -->
    <LinearLayout
        android:id="@+id/btn_pause"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:background="@drawable/notif_btn_primary">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pause"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Resume button (paused) -->
    <LinearLayout
        android:id="@+id/btn_resume"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:background="@drawable/notif_btn_primary"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resume"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- btn_stop kept as zero-size — required by Kotlin buildViews -->
    <LinearLayout
        android:id="@+id/btn_stop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
